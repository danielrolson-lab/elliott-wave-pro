{
  "expo": {
    "name": "Elliott Wave Pro",
    "slug": "elliott-wave-pro",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "com.elliottwave.pro",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.elliottwave.pro",
      "usesAppleSignIn": true,
      "deploymentTarget": "16.0",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Elliott Wave Pro uses the microphone for voice navigation commands.",
        "NSCameraUsageDescription": "Elliott Wave Pro may use the camera for profile photos.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.elliottwave.pro",
      "versionCode": 1,
      "minSdkVersion": 26,
      "targetSdkVersion": 34,
      "compileSdkVersion": 34,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#000000"
        }
      ],
      [
        "expo-local-authentication"
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "elliott-wave-pro"
      }
    }
  }
}
