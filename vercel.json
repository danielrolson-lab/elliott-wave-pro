{
  "version": 2,
  "builds": [
    { "src": "services/proxy/api/*.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/health",                   "dest": "/services/proxy/api/health" },
    { "src": "/api/milkyway(.*)",         "dest": "/services/proxy/api/milkyway" },
    { "src": "/api/wave-compute(.*)",     "dest": "/services/proxy/api/wave-compute" },
    { "src": "/api/ai-commentary",        "dest": "/services/proxy/api/ai-commentary" },
    { "src": "/api/alert-intelligence",   "dest": "/services/proxy/api/alert-intelligence" },
    { "src": "/api/quant-api",            "dest": "/services/proxy/api/quant-api" },
    { "src": "/api/(.*)",                 "dest": "/services/proxy/api/$1" }
  ]
}
