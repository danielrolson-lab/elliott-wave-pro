# Polygon.io — get your key at https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=your_polygon_api_key_here

# WebSocket proxy URL (set in apps/mobile/.env.local for Expo)
# Local dev:  ws://localhost:3001
# Production: wss://your-vercel-app.vercel.app/api/ws
EXPO_PUBLIC_WS_PROXY_URL=ws://localhost:3001

# Supabase (Phase 3)
SUPABASE_URL=
SUPABASE_ANON_KEY=
