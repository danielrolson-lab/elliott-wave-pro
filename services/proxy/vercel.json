{
  "version": 2,
  "public": true,
  "builds": [
    { "src": "api/quant-api.ts",       "use": "@vercel/node" },
    { "src": "ai-commentary.ts",       "use": "@vercel/node" },
    { "src": "alert-intelligence.ts",  "use": "@vercel/node" },
    { "src": "wave-compute.ts",        "use": "@vercel/node" },
    { "src": "milkyway.ts",            "use": "@vercel/node" },
    { "src": "public/**",              "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/privacy",               "dest": "/public/privacy.html" },
    { "src": "/support",               "dest": "/public/support.html" },
    { "src": "/api/quant-api(.*)",     "dest": "/api/quant-api.ts" },
    { "src": "/api/ai-commentary",     "dest": "/ai-commentary.ts" },
    { "src": "/api/alert-intelligence","dest": "/alert-intelligence.ts" },
    { "src": "/api/wave-compute",      "dest": "/wave-compute.ts" },
    { "src": "/api/milkyway",          "dest": "/milkyway.ts" },
    { "src": "/health",                "dest": "/api/quant-api.ts" }
  ]
}
